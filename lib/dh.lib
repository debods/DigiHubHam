#!/usr/bin/env bash
# DigiHub UI helpers (colors + layout)
# Safe to source from any bash script.

# ---- Color helpers (auto-off if not a terminal / NO_COLOR set) ----
color_on=true
if [ ! -t 1 ] || [ -n "${NO_COLOR:-}" ]; then
  color_on=false
fi

c() { $color_on && tput "$@" || true; }

RESET="$(c sgr0)"
BOLD="$(c bold)"
DIM="$(c dim)"

FG_WHITE="$(c setaf 7)"
FG_CYAN="$(c setaf 6)"
FG_GREEN="$(c setaf 2)"
FG_YELLOW="$(c setaf 3)"
FG_RED="$(c setaf 1)"
FG_BLUE="$(c setaf 4)"

# Normal output styles
HEAD="${BOLD}${FG_CYAN}"
LABEL="${BOLD}${FG_WHITE}"
VALUE="${FG_WHITE}"
MUTED="${DIM}${FG_WHITE}"

# Error output styles
ERR_HEAD="${BOLD}${FG_RED}"
ERR_LABEL="${BOLD}${FG_WHITE}"
ERR_VALUE="${FG_WHITE}"

section() { # section "Title"
  printf "\n${BOLD}${FG_BLUE}%s${RESET}\n" "$1"
}

kv() { # kv "Label" "Value"
  printf "  ${LABEL}%-14s${RESET} ${VALUE}%s${RESET}\n" "$1" "${2:-N/A}"
}

err_section() { # err_section "Title"
  printf "\n${ERR_HEAD}%s${RESET}\n" "$1" >&2
}

err_kv() { # err_kv "Label" "Value"
  printf "  ${ERR_LABEL}%-14s${RESET} ${ERR_VALUE}%s${RESET}\n" "$1" "${2:-}" >&2
}

die() { # die "Title" "Message" [exit_code]
  local title="${1:-Error}"
  local msg="${2:-}"
  local code="${3:-1}"
  err_section "$title"
  [ -n "$msg" ] && err_kv "Message" "$msg"
  printf "\n" >&2
  exit "$code"
}

need_file() { # need_file "/path/to/file" "what to do"
  local f="$1"
  local action="${2:-}"
  if [ ! -r "$f" ]; then
    err_section "Configuration Missing"
    err_kv "File" "$f"
    [ -n "$action" ] && err_kv "Action" "$action"
    printf "\n" >&2
    exit 1
  fi
}

run_sudo() { # run_sudo <command> [args...] -- skips sudo if already root
  if [ "${EUID}" -eq 0 ]; then
    "$@"
  else
    sudo "$@"
  fi
}

# systemctl only knows about units already present in /etc/systemd/system;
# on-demand services (not enabled unconditionally by install.sh) only have
# their template cached in /usr/local/lib/digihub until something actually
# needs them. Installs one on first use, rendering __DIGIHUB_USER__ the
# same way install.sh does. Returns non-zero (with a message on stderr) if
# the cached template is missing or the install fails.
ensure_unit_installed() { # ensure_unit_installed "some.service"
  local dest="/etc/systemd/system/$1" src="/usr/local/lib/digihub/$1" tmp

  run_sudo test -f "$dest" && return 0

  if [ ! -f "$src" ]; then
    printf 'Error: unit template not found: %s\n' "$src" >&2
    printf 'Run dhupdate to restore DigiHub'"'"'s installed files.\n' >&2
    return 1
  fi

  tmp="$(mktemp)"
  sed -e "s|__DIGIHUB_USER__|$(id -un)|" "$src" > "$tmp"
  if ! run_sudo install -m 0644 "$tmp" "$dest"; then
    rm -f "$tmp"
    printf 'Error: could not install unit file: %s\n' "$dest" >&2
    return 1
  fi
  rm -f "$tmp"
  run_sudo systemctl daemon-reload || true
}

status_tag() {
  case "$1" in
    Active)
      printf "%sACTIVE%s" "$FG_GREEN" "$RESET"
      ;;
    Expired)
      printf "%sEXPIRED%s" "$FG_RED" "$RESET"
      ;;
    *)
      printf "%sUNKNOWN%s" "$FG_YELLOW" "$RESET"
      ;;
  esac
}
