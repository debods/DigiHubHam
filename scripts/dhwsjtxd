#!/usr/bin/env bash

: <<'END'
dhwsjtxd
DigiHub WSJT-X VNC session wrapper - starts a TigerVNC desktop + noVNC
bridge and runs WSJT-X on it

Version 0.1

Steve de Bode - W0FFS - July 2026

Input:	none - runs continuously under systemd (unit: dhwsjtx.service)
	reads $HOME/.config/tigervnc/{xstartup,passwd}, generated by
	install.sh from $HOME/.dhinfo's vncpass
Output:	none - runs WSJT-X (via a VNC desktop) until stopped
END

set -uo pipefail

UI_LIB="/usr/local/lib/digihub/dh.lib"
[ -r "$UI_LIB" ] && source "$UI_LIB" || {
  printf "\nERROR: Missing UI library: %s\n\n" "$UI_LIB" >&2
  exit 1
}

if ! command -v wsjtx >/dev/null 2>&1; then
  err_section "DigiHub WSJT-X"
  err_kv "Message" "wsjtx is not installed."
  err_kv "Action" "sudo apt-get install wsjtx"
  printf "\n" >&2
  exit 1
fi

if ! command -v vncserver >/dev/null 2>&1; then
  err_section "DigiHub WSJT-X"
  err_kv "Message" "vncserver is not installed."
  err_kv "Action" "sudo apt-get install tigervnc-standalone-server tigervnc-tools novnc websockify"
  printf "\n" >&2
  exit 1
fi

section "DigiHub WSJT-X"
kv "VNC"   ":1 (port 5901)"
kv "noVNC" "port 6080"
printf "\n"

run_vnc_session wsjtx wsjt
