#!/usr/bin/env bash

: <<'END'
dhremove
DigiHub Uninstaller

Version 0.2

Steve de Bode - W0FFS - July 2026

Input:  interactive by default
        --yes        assume yes for removal prompt
        --no-reboot  do not prompt for reboot
        --files-only remove only DigiHub files listed in /usr/local/bin/.digihub.manifest
Output: interactive by default
END

set -euo pipefail

if [[ -n "${SUDO_USER:-}" && "$SUDO_USER" != "root" ]]; then
  HomePath="$(getent passwd "$SUDO_USER" | cut -d: -f6)"
else
  HomePath="${HOME}"
fi

venv_dir="${HomePath}/.digihub-venv"
MANIFEST="/usr/local/bin/.digihub.manifest"
LIBDIR="/usr/local/lib/digihub"
ASSUME_YES=0
PROMPT_REBOOT=1
REMOVE_PACKAGES=1
REMOVE_PROFILE=1
REMOVE_DHINFO=1
REMOVE_VENV=1
REMOVE_MANIFEST_FILES=1

while (( $# > 0 )); do
  case "$1" in
    -y|--yes)
      ASSUME_YES=1
      ;;
    --no-reboot)
      PROMPT_REBOOT=0
      ;;
    --keep-packages|--no-packages)
      REMOVE_PACKAGES=0
      ;;
    --keep-profile|--no-profile)
      REMOVE_PROFILE=0
      ;;
    --keep-dhinfo|--no-dhinfo)
      REMOVE_DHINFO=0
      ;;
    --keep-venv|--no-venv)
      REMOVE_VENV=0
      ;;
    --keep-files|--no-files)
      REMOVE_MANIFEST_FILES=0
      ;;
    --files-only)
      REMOVE_PACKAGES=0
      REMOVE_PROFILE=0
      REMOVE_DHINFO=0
      REMOVE_VENV=0
      REMOVE_MANIFEST_FILES=1
      PROMPT_REBOOT=0
      ASSUME_YES=1
      ;;
    -h|--help)
      sed -n '/^: <<'\''END'\''/,/^END$/p' "$0" | sed '1d;$d'
      exit 0
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      exit 2
      ;;
  esac
  shift
done

confirm_remove() {
  local response=""

  if (( ASSUME_YES == 1 )); then
    printf '\nRemoving DigiHub.\n'
    return 0
  fi

  while true; do
    printf '\nThis action will completely remove DigiHub, continue (Y/n)? '
    read -n1 -r response </dev/tty
    case "$response" in
      Y|y)
        printf '\nRemoving DigiHub.\n'
        return 0
        ;;
      N|n)
        printf '\nUninstall aborted.\n\n'
        exit 0
        ;;
      *)
        printf '\nInvalid response, please select Y/n.\n'
        ;;
    esac
  done
}

restore_profile() {
  (( REMOVE_PROFILE == 1 )) || return 0

  if [[ -f "$HomePath/.profile.dh" ]]; then
    mv -f -- "$HomePath/.profile.dh" "$HomePath/.profile" >/dev/null 2>&1 || true
  elif [[ -f "$HomePath/.profile" ]]; then
    local tmp
    tmp="$HomePath/.profile.tmp.$$"
    grep -vF -e 'DigiHub' -e 'sysinfo' "$HomePath/.profile" > "$tmp" 2>/dev/null || true
    mv -f -- "$tmp" "$HomePath/.profile" >/dev/null 2>&1 || true
  fi

  if [[ -f "$HomePath/.profile" ]]; then
    perl -i.bak -0777 -pe 's{\s+\z}{}m' "$HomePath/.profile" >/dev/null 2>&1 || true
    printf '\n' >> "$HomePath/.profile" 2>/dev/null || true
    rm -f -- "$HomePath/.profile.bak"* >/dev/null 2>&1 || true
  fi
}

remove_manifest_files() {
  (( REMOVE_MANIFEST_FILES == 1 )) || return 0

  if [[ -r "$MANIFEST" ]]; then
    while IFS= read -r p; do
      [[ -n "${p//[[:space:]]/}" ]] || continue

      case "$p" in
        /usr/local/bin/*|/usr/local/lib/digihub/*) ;;
        *) continue ;;
      esac

      [[ "$p" != "/usr/local/bin" && "$p" != "/usr/local/lib/digihub" ]] || continue
      [[ "$p" != *"*"* && "$p" != *"?"* && "$p" != *"["* ]] || continue

      if sudo test -f "$p" || sudo test -L "$p"; then
        sudo rm -f -- "$p" >/dev/null 2>&1 || true
      fi
    done < "$MANIFEST"

    sudo rm -f -- "$MANIFEST" >/dev/null 2>&1 || true
  fi

  sudo rm -rf -- /usr/local/bin/__pycache__ >/dev/null 2>&1 || true

  if sudo test -d "$LIBDIR"; then
    sudo rmdir --ignore-fail-on-non-empty "$LIBDIR" >/dev/null 2>&1 || true
  fi
}

remove_packages() {
  (( REMOVE_PACKAGES == 1 )) || return 0

  if [[ -f "$HomePath/.dhinstalled" ]]; then
    while IFS= read -r pkg; do
      [[ -n "${pkg//[[:space:]]/}" ]] || continue
      [[ "$pkg" =~ ^[A-Za-z0-9][A-Za-z0-9+._-]*$ ]] || continue

      if dpkg -s "$pkg" >/dev/null 2>&1; then
        sudo apt-get -y purge "$pkg" >/dev/null 2>&1 || true
      fi
    done < "$HomePath/.dhinstalled"

    sudo apt-get -y autoremove >/dev/null 2>&1 || true
    rm -f -- "$HomePath/.dhinstalled" >/dev/null 2>&1 || true
  else
    printf 'Warning: %s not found; no DigiHub package list was available.\n' "$HomePath/.dhinstalled" >&2
  fi
}

remove_user_files() {
  if (( REMOVE_DHINFO == 1 )); then
    rm -f -- "$HomePath/.dhinfo" "$HomePath/.dhinfo.last" >/dev/null 2>&1 || true
  fi

  if (( REMOVE_VENV == 1 )); then
    sudo rm -rf -- "$venv_dir" >/dev/null 2>&1 || true
  fi
}

prompt_reboot() {
  (( PROMPT_REBOOT == 1 )) || return 0

  local response=""
  while true; do
    printf '\nReboot now (Y/n)? '
    read -n1 -r response </dev/tty
    case "$response" in
      Y|y)
        printf '\nRebooting\n'
        sudo reboot
        break
        ;;
      N|n)
        printf '\nA reboot is required to completely remove DigiHub.\n\n'
        break
        ;;
      *)
        printf '\nInvalid response, please select Y/n.\n'
        ;;
    esac
  done
}

confirm_remove
deactivate >/dev/null 2>&1 || true

restore_profile
remove_manifest_files
remove_packages
remove_user_files

printf 'DigiHub removal complete.\n'
prompt_reboot
