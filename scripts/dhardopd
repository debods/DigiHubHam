#!/usr/bin/env bash

: <<'END'
dhardopd
DigiHub ARDOP TNC service wrapper

Version 0.1

Steve de Bode - W0FFS - July 2026

Input:	none - runs continuously under systemd (unit: dhardop.service)
	audio device is auto-detected via audiodetect.py; PTT is left to
	Pat + Hamlib/rigctld (see patconf.py), not configured here
Output:	none - runs ardopcf until stopped
END

set -uo pipefail

UI_LIB="/usr/local/lib/digihub/dh.lib"
[ -r "$UI_LIB" ] && source "$UI_LIB" || {
  printf "\nERROR: Missing UI library: %s\n\n" "$UI_LIB" >&2
  exit 1
}

if ! command -v ardopcf >/dev/null 2>&1; then
  err_section "DigiHub ARDOP"
  err_kv "Message" "ardopcf is not installed."
  err_kv "Action" "Install it from https://github.com/pflarue/ardop/releases"
  printf "\n" >&2
  exit 1
fi

PORT=8515
WEBGUI_PORT=8514

# Unlike direwolf, ardopcf does not fall back gracefully when no audio
# device is given -- it tries an ALSA alias literally named "ARDOP" and
# exits if that alias isn't configured. Refuse to start rather than
# exec into a crash loop.
device="$(python3 /usr/local/bin/audiodetect.py 2>/dev/null || true)"

if [[ -z "$device" ]]; then
  err_section "DigiHub ARDOP"
  err_kv "Message" "Could not confidently auto-detect the radio's audio device."
  err_kv "Action" "Run 'arecord -l' to identify it, then edit dhardop.service's ExecStart to add it manually."
  printf "\n" >&2
  exit 1
fi

section "DigiHub ARDOP"
kv "Port"    "$PORT"
kv "Web GUI" "$WEBGUI_PORT"
kv "Device"  "$device"
printf "\n"

exec ardopcf -m -G "$WEBGUI_PORT" "$PORT" "$device" "$device"
